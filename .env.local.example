# Google Gemini API Key
GEMINI_API_KEY="your_gemini_api_key_here"
GOOGLE_GENERATIVE_AI_API_KEY="your_gemini_api_key_here"

# Matikan warning log AI SDK agar tidak menyebabkan error di Edge Runtime
AI_SDK_LOG_WARNINGS=false

# Koneksi Database PostgreSQL (Neon Serverless / Supabase / Postgres.js)
DATABASE_URL="postgresql://username:password@ep-your-project-id.region.aws.neon.tech/neondb?sslmode=require"
